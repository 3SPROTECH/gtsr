# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gtsr?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10

# --- SMTP (optional - leave empty to disable email sending) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GTSR Helpdesk <no-reply@gtsr.local>"
